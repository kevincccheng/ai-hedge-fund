# PRIMARY: Anthropic Claude
ANTHROPIC_API_KEY=your-key-here

# SECONDARY: OpenAI
OPENAI_API_KEY=your-key-here

# OPTIONAL: DeepSeek (cheapest)
DEEPSEEK_API_KEY=your-key-here

# Financial data (required for non-US5 tickers)
# Free tier: AAPL, GOOGL, MSFT, NVDA, TSLA only
# Paid tier needed for HK tickers
FINANCIAL_DATASETS_API_KEY=your-key-here

# Model config - uncomment ONE block:

# --- BLOCK 1: Anthropic (best quality, ~$1.50-2.00/run) ---
# LLM_PROVIDER=Anthropic
# LLM_MODEL=claude-sonnet-4-6

# --- BLOCK 2: DeepSeek (excellent value, ~$0.10-0.20/run) ---
# LLM_PROVIDER=DeepSeek
# LLM_MODEL=deepseek-chat

# --- BLOCK 3: OpenAI (good, ~$0.50-1.00/run) ---
# LLM_PROVIDER=OpenAI
# LLM_MODEL=gpt-4o
